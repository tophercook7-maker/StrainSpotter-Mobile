{
  "expo": {
    "name": "StrainSpotter",
    "slug": "strainspotter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "strainspotter",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1F0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mixedmakershop.strainspotter",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "StrainSpotter uses your camera to identify cannabis strains using AI.",
        "NSPhotoLibraryUsageDescription": "StrainSpotter accesses your photo library so you can scan saved images.",
        "NSLocationWhenInUseUsageDescription": "StrainSpotter uses your location to find nearby dispensaries.",
        "NSUserTrackingUsageDescription": "Used to improve personalized recommendations.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1F0D"
      },
      "package": "com.mixedmakershop.strainspotter",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "StrainSpotter uses your camera to identify cannabis strains using AI."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "StrainSpotter accesses your photos so you can scan saved images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "8218a1b2-e62d-47da-aa53-6da4db16b1aa"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "topher1"
  }
}
